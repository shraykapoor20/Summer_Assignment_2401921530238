class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int n = nums.size();
        vector<int> leftSum(n, 0);
        vector<int> rightSum(n, 0);
        vector<int> ans(n, 0);
        leftSum[0] = 0;
        rightSum[n-1] = 0;
        for(int i=1; i<n; i++){
            leftSum[i] = leftSum[i-1] + nums[i-1];
        }
        for(int i=n-1; i>=0; i--){
            if(i == n-1){
                ans[i] = leftSum[i];
                continue;
            }
            rightSum[i] = rightSum[i+1] + nums[i+1];
            ans[i] = abs(rightSum[i] - leftSum[i]);
        }
        return ans;
    }
};
