class Solution {
public:
    ListNode *getIntersectionNode(ListNode *headA, ListNode *headB) {
        int len1 = 0;
        ListNode * curr1 = headA;
        while(curr1 != nullptr){
            len1++;
            curr1 = curr1->next;
        }
        int len2 = 0;
        ListNode * curr2 = headB;
        while(curr2 != nullptr){
            len2++;
            curr2 = curr2->next;
        }
        curr1 = headA;
        curr2 = headB;
        int d = abs(len1 - len2);
        if(len1 > len2){
            while(d > 0){
                curr1 = curr1->next;
                d--;
            }
        }
        if(len2 > len1){
            while(d > 0){
                curr2 = curr2->next;
                d--;
            }
        }
        while(curr1 != nullptr && curr2 != nullptr){
            if(curr1 == curr2)
                return curr1;
            curr1 = curr1->next;
            curr2 = curr2->next;
        }
        return nullptr;
    }
};
