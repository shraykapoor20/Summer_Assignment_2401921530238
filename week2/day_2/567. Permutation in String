class Solution {
public:
    bool areSame(int CT[], int CP[]){
        for(int i = 0; i < 256; i++){
            if(CT[i] != CP[i])
                return false;
        }
        return true;
    }
    bool checkInclusion(string s1, string s2) {
        if(s1.length() > s2.length())
            return false;
        int CT[256] = {0};
        int CP[256] = {0};
        for(int i=0; i<s1.length(); i++){
            CT[s2[i]]++;
            CP[s1[i]]++;
        }
        for(int i=s1.length(); i<s2.length(); i++){
            if(areSame(CT, CP))
                return true;
            CT[s2[i]]++;
            CT[s2[i-s1.length()]]--;
        }
        return areSame(CT, CP);
    }
};
