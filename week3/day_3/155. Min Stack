class MinStack {
public:
    stack<int> ms;
    stack<int> as;

    MinStack() {
        
    }
    
    void push(int value) {
        ms.push(value);
        if(as.empty() || value <= as.top())
            as.push(value);
    }
    
    void pop() {
        if(as.top() == ms.top())
            as.pop();
        ms.pop();
    }
    
    int top() {
        return ms.top();
    }
    
    int getMin() {
        return as.top();
    }
};
