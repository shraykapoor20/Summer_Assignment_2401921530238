class Solution {
public:
    ListNode* mergeTwoLists(ListNode* list1, ListNode* list2) {

        if (list1 == nullptr)
            return list2;
        if (list2 == nullptr)
            return list1;

        ListNode* a = list1;
        ListNode* b = list2;
        ListNode* head = nullptr;
        ListNode* curr = nullptr;

        if (a->val <= b->val) {
            head = a;
            curr = a;
            a = a->next;
        } else {
            head = b;
            curr = b;
            b = b->next;
        }

        while (a != nullptr && b != nullptr) {
            if (a->val <= b->val) {
                curr->next = a;
                a = a->next;
                curr = curr->next;
            } else {
                curr->next = b;
                b = b->next;
                curr = curr->next;
            }
        }

        if (a != nullptr) {
            curr->next = a;
        }
        if (b != nullptr) {
            curr->next = b;
        }

        return head;
    }
};
